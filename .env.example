# ── Database (Railway provides this automatically) ─────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public

# ── Auth (Clerk) ──────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
JWT_SECRET=generate-a-strong-random-secret

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
APP_URL=https://your-app.up.railway.app
ALERT_MAINTENANCE_THRESHOLD=50000

# ── Platform admin (internal /performance dashboard) ───────────────────────
# Comma-separated emails; must match the signed-in user email in the DB.
FLEETSURE_PLATFORM_ADMIN_EMAILS=you@company.com

# ── Telegram Bots ──────────────────────────────────────────────────────────
# Create bots via @BotFather on Telegram and paste tokens here
# Long-polling: one process per bot token. Default = on in production only (avoids 409 vs local dev).
# TELEGRAM_POLLING=true   force on | false force off (e.g. spare Railway env)
TELEGRAM_POLLING=
# Webhook mode (recommended for multi-instance production):
# TELEGRAM_WEBHOOK=true
# TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.com
# TELEGRAM_DRIVER_WEBHOOK_SECRET=change-me-driver
# TELEGRAM_OWNER_WEBHOOK_SECRET=change-me-owner
TELEGRAM_WEBHOOK=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_DRIVER_WEBHOOK_SECRET=
TELEGRAM_OWNER_WEBHOOK_SECRET=
TELEGRAM_DRIVER_BOT_TOKEN=
TELEGRAM_OWNER_BOT_TOKEN=
FLEET_INVITE_CODE=FLEET-XXXX

# ── AI ─────────────────────────────────────────────────────────────────────
# GROQ_API_KEY: fleet AI + trip auto-estimate India diesel (INR/L) suggestion
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Third-party APIs (optional) ───────────────────────────────────────────
SUREPASS_API_BASE_URL=https://sandbox.surepass.app
SUREPASS_API_TOKEN=
BULKPE_API_KEY=
OPENROUTE_API_KEY=
FUEL_PRICE_API_URL=
FUEL_PRICE_API_KEY=
