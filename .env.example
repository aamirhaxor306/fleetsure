# ── Database (Railway provides this automatically) ─────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public

# ── Auth (Clerk) ──────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
JWT_SECRET=generate-a-strong-random-secret

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
APP_URL=https://your-app.up.railway.app
ALERT_MAINTENANCE_THRESHOLD=50000

# ── Telegram Bots ──────────────────────────────────────────────────────────
# Create bots via @BotFather on Telegram and paste tokens here
# Long-polling: one process per bot token. Default = on in production only (avoids 409 vs local dev).
# TELEGRAM_POLLING=true   force on | false force off (e.g. spare Railway env)
TELEGRAM_POLLING=
TELEGRAM_DRIVER_BOT_TOKEN=
TELEGRAM_OWNER_BOT_TOKEN=
OWNER_TELEGRAM_CHAT_ID=
FLEET_INVITE_CODE=FLEET-XXXX

# ── AI ─────────────────────────────────────────────────────────────────────
# GROQ_API_KEY: fleet AI + trip auto-estimate India diesel (INR/L) suggestion
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Third-party APIs (optional) ───────────────────────────────────────────
SUREPASS_API_TOKEN=
BULKPE_API_KEY=
OPENROUTE_API_KEY=
FUEL_PRICE_API_URL=
FUEL_PRICE_API_KEY=
