{
  "name": "fleetsure",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "overrides": {
    "jose": "4.15.9"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npx vite",
    "build": "npx prisma generate && cd client && npx vite build",
    "start": "npm run db:deploy && NODE_ENV=production node server/index.js",
    "postinstall": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:deploy": "npx prisma db push --accept-data-loss",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:setup": "npx prisma db push && node prisma/seed.js",
    "db:wipe:fleet": "node prisma/wipeFleetData.js"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@types/leaflet": "^1.9.21",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.0",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "leaflet": "^1.9.4",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.41",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^1.2.0"
  }
}
